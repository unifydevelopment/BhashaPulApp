<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bhasha Pul"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jo bhi bhasha aap chahte hain, wo select karein. Ye har app ke andar text ko usi bhasha mein translate karega."
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aapki bhasha (target language)" />

    <Spinner
        android:id="@+id/targetLangSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnOverlayPermission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. Overlay permission dein" />

    <Button
        android:id="@+id/btnAccessibilitySettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="2. Accessibility mein Bhasha Pul on karein" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Dono steps poore karne ke baad, kisi bhi app ko khol kar dekhein — translation overlay apne aap aa jayega." />

</LinearLayout>
