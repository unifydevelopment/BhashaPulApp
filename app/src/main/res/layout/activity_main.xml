<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bhasha Pul"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Screen translate karne ke liye aur voice se kahin bhi type karne ke liye, neeche settings karein."
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Screen translation: aapki bhasha (target language)" />

    <Spinner
        android:id="@+id/targetLangSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voice typing: aap kis bhasha mein bolenge" />

    <Spinner
        android:id="@+id/voiceLangSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnOverlayPermission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. Overlay permission dein" />

    <Button
        android:id="@+id/btnAccessibilitySettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="2. Accessibility mein Bhasha Pul on karein" />

    <Button
        android:id="@+id/btnVoiceTyping"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="3. Voice typing shuru karein" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Steps 1 aur 2 poore karne ke baad, koi bhi app kholkar message par tap/long-press karein translation ke liye. Step 3 on karne ke baad, floating mic button kisi bhi text box mein bolke likhne ke liye milega." />

</LinearLayout>
</ScrollView>
